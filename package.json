{
  "name": "leaflet-atlas",
  "version": "0.1.1",
  "type": "module",
  "description": "A config-driven Leaflet framework for building interactive GeoJSON map applications",
  "main": "./dist/leaflet-atlas.umd.js",
  "module": "./dist/leaflet-atlas.js",
  "browser": "./dist/leaflet-atlas.umd.js",
  "unpkg": "./dist/leaflet-atlas.umd.js",
  "jsdelivr": "./dist/leaflet-atlas.umd.js",
  "style": "./dist/leaflet-atlas.css",
  "exports": {
    ".": {
      "import": "./dist/leaflet-atlas.js",
      "require": "./dist/leaflet-atlas.umd.js"
    },
    "./css": "./dist/leaflet-atlas.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "lint": "eslint . && markdownlint-cli2 README.md 'docs/**/*.md'",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "leaflet": "^1.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "markdownlint-cli2": "^0.21.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "leaflet",
    "map",
    "atlas",
    "geojson",
    "interactive-map"
  ],
  "author": "rlespinasse",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rlespinasse/leaflet-atlas.git"
  }
}
